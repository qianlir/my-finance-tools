/* === 布局 === */
.container {
  padding: 12px;
  padding-bottom: 24px;
}

.card {
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

/* === 标题栏 === */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.title {
  font-size: 16px;
  font-weight: bold;
  color: #1a73e8;
}

.updated {
  font-size: 11px;
  color: #999;
}

/* === 期货区域 === */
.futures-section {
  padding: 10px 12px;
}

.futures-row {
  font-size: 12px;
  line-height: 22px;
}

.futures-label {
  color: #666;
}

.divider {
  color: #ccc;
}

.freshness {
  margin-top: 4px;
  font-size: 11px;
  color: #999;
  padding-left: 8px;
  border-left: 2px solid #dadce0;
}

/* === 表格区域 === */
.section {
  padding-bottom: 8px;
}

.section-title {
  display: block;
  font-size: 15px;
  font-weight: bold;
  color: #333;
  padding: 10px 12px 8px;
}

/* 固定列 + 滚动区域 */
.table-wrapper {
  display: flex;
  flex-direction: row;
  border-top: 1px solid #e0e0e0;
}

.fixed-col {
  flex-shrink: 0;
  width: 56px;
  border-right: 2px solid #1a73e8;
  z-index: 2;
  background: #fff;
}

.fixed-th {
  background: #1a73e8 !important;
  color: #fff !important;
  font-weight: bold;
}

.fixed-td {
  border-bottom: 1px solid #f0f0f0;
}

.code-text {
  font-weight: bold;
  font-size: 11px;
  color: #333;
}

.scroll-area {
  flex: 1;
  width: 0;
}

.scroll-inner {
  display: inline-flex;
  flex-direction: column;
}

/* 行 */
.row {
  display: flex;
  flex-direction: row;
}

.header-row {
  background: #1a73e8;
}

.header-row .th {
  color: #fff;
  font-weight: bold;
}

.data-row {
  border-bottom: 1px solid #f0f0f0;
}

/* 单元格 */
.cell {
  flex-shrink: 0;
  width: 68px;
  padding: 6px 3px;
  font-size: 11px;
  text-align: center;
  line-height: 18px;
  box-sizing: border-box;
}

.cell.wide {
  width: 115px;
}

.cell.narrow {
  width: 42px;
}

.cell.rec-col {
  width: 96px;
  font-size: 10px;
}

.cell.th {
  font-size: 10px;
}

/* === 行高亮（按推荐等级） === */
.rec-top {
  background: #e8f5e9;
}

.rec-top .code-text {
  color: #2e7d32;
}

.rec-good {
  background: #fff8e1;
}

.rec-neutral {
  background: #fff;
}

.rec-sell {
  background: #fce8e6;
}

/* === 注释 === */
.section-notes {
  padding: 8px 12px 0;
}

.formula-notes {
  padding: 10px 12px;
}

.note {
  display: block;
  font-size: 11px;
  color: #666;
  line-height: 18px;
  padding-left: 8px;
  border-left: 2px solid #dadce0;
  margin-bottom: 4px;
}

/* === 免责声明 === */
.disclaimer {
  text-align: center;
  padding: 8px 0;
  font-size: 11px;
  color: #999;
}

/* === 状态页 === */
.loading, .error {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400px;
  font-size: 14px;
}

.loading {
  color: #999;
}

.error {
  color: #e53935;
}
