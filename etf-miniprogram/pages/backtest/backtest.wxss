/* pages/backtest/backtest.wxss */
.container {
  padding: 12px;
  background: #f8f9fa;
  min-height: 100vh;
}

.form-card {
  background: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.label {
  font-size: 14px;
  color: #333;
}

.picker {
  font-size: 14px;
  color: #1a73e8;
  padding: 8px 12px;
  background: #f0f7ff;
  border-radius: 4px;
}

.btn-start {
  background: #1a73e8;
  color: #fff;
  border-radius: 20px;
  margin-top: 8px;
}

.btn-start[disabled] {
  background: #ccc;
}

.result-section {
  margin-top: 12px;
}

.period-info {
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.period-info text {
  font-size: 12px;
  color: #666;
}

.section {
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 15px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
}

.subsection-title {
  font-size: 13px;
  font-weight: bold;
  color: #666;
  margin: 16px 0 8px;
}

.strategies-table, .etf-table {
  border-radius: 4px;
  overflow: hidden;
}

.table-row {
  display: flex;
  border-bottom: 1px solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row.header {
  background: #1a73e8;
}

.table-row.header .cell {
  color: #fff;
  font-weight: bold;
  font-size: 11px;
}

.cell {
  flex: 1;
  padding: 8px 4px;
  text-align: center;
  font-size: 11px;
  color: #333;
  border-right: 1px solid #f0f0f0;
}

.cell:last-child {
  border-right: none;
}

.cell.name, .cell.code {
  flex: 1.2;
}

.red { color: #e53935; }
.green { color: #43a047; }

.best-etf-card {
  margin-top: 12px;
  padding: 12px;
  background: #e8f5e9;
  border-radius: 4px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
}

.empty-state, .loading {
  text-align: center;
  padding: 60px 20px;
  color: #999;
  font-size: 14px;
}
