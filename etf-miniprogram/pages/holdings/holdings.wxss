/* pages/holdings/holdings.wxss */
.container {
  padding: 12px;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
}

.top-bar .title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin: 0;
}

.settings-btn {
  font-size: 13px;
  color: #1a73e8;
}

/* 登录卡片 */
.login-card {
  background: #fff;
  border-radius: 8px;
  padding: 40px 20px;
  text-align: center;
}

.login-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.login-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.login-desc {
  font-size: 13px;
  color: #666;
  margin-bottom: 20px;
}

.btn-settings {
  background: #1a73e8;
  color: #fff;
  padding: 12px 32px;
  border-radius: 20px;
  font-size: 14px;
}

/* 已登录状态 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 8px;
  padding: 12px 16px;
  margin-bottom: 12px;
}

.header .title {
  font-size: 16px;
  margin: 0;
}

.header-actions {
  display: flex;
  gap: 16px;
}

.logout, .refresh {
  font-size: 13px;
  color: #1a73e8;
}

/* 持仓列表 */
.holdings-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.holding-card {
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  border-left: 4px solid #43a047;
}

.holding-card.warning {
  border-left-color: #ff9800;
  background: #fff8f0;
}

.holding-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.code {
  font-size: 14px;
  font-weight: bold;
  color: #333;
}

.name {
  font-size: 13px;
  color: #666;
  flex: 1;
  margin-left: 8px;
}

.status {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
}

.status.buy {
  background: #e8f5e9;
  color: #43a047;
}

.status.hold {
  background: #fff3e0;
  color: #ef6c00;
}

.holding-detail {
  display: flex;
  gap: 16px;
  margin-bottom: 8px;
}

.metric {
  font-size: 12px;
  color: #666;
}

.holding-metrics {
  display: flex;
  justify-content: space-around;
  padding: 8px 0;
  border-top: 1px solid #f0f0f0;
  border-bottom: 1px solid #f0f0f0;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-item .label {
  font-size: 11px;
  color: #999;
  margin-bottom: 4px;
}

.metric-item .value {
  font-size: 14px;
  font-weight: bold;
  color: #333;
}

/* 换仓建议 */
.swap-suggestion {
  margin-top: 8px;
  padding: 8px 12px;
  background: #fff3e0;
  border-radius: 4px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4px;
}

.swap-icon {
  font-size: 14px;
}

.swap-text {
  font-size: 12px;
  color: #ef6c00;
}

.swap-reason {
  font-size: 11px;
  color: #666;
}

/* 空状态和加载 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: #333;
  margin-bottom: 4px;
}

.empty-hint {
  font-size: 12px;
  color: #999;
}

.loading {
  text-align: center;
  padding: 60px 20px;
  color: #999;
}

.red { color: #e53935; }
.green { color: #43a047; }
